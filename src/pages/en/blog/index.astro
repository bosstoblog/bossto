---
import Base from '../../../layouts/Base.astro';
import Support from '../../../components/Support.astro';
---
<Base title="Blog" lang="en">
  <style>
    .blog-header {
      padding: 4rem 0 3rem;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      margin-bottom: 3rem;
      animation: fadeUp 0.6s 0.1s ease both;
    }
    .blog-header h1 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 900;
      letter-spacing: -0.04em;
      background: linear-gradient(160deg, #ffffff 40%, #444 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 0.75rem;
    }
    .blog-header p {
      font-size: 0.9rem;
      color: #333;
      font-weight: 500;
    }
    .empty-state {
      animation: fadeUp 0.6s 0.25s ease both;
      padding: 3rem 0;
    }
    .empty-state p {
      font-size: 0.95rem;
      color: #333;
      line-height: 1.7;
    }
    .support-wrap {
      animation: fadeUp 0.6s 0.38s ease both;
    }
  </style>

  <div class="blog-header">
    <h1>Blog</h1>
    <p>Animated essays & visual explainers.</p>
  </div>
  <div class="empty-state">
    <p>First videos and posts are in progress. Subscribe to be first.</p>
  </div>
  <div class="support-wrap">
    <Support lang="en" />
  </div>
</Base>
