---
// Auto-detect language and redirect
---
<html>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>bossto</title>
    <script>
      const saved = localStorage.getItem('bossto-lang');
      const browser = navigator.language || '';
      const lang = saved || (browser.toLowerCase().startsWith('ru') ? 'ru' : 'en');
      localStorage.setItem('bossto-lang', lang);
      window.location.replace('/' + lang + '/');
    </script>
  </head>
  <body></body>
</html>
