---

<div class="socials">
  {socials.map(s => (
    <a href={s.url} target="_blank" rel="noopener noreferrer" title={s.label}>
      <span class="icon" set:html={icons[s.icon]} />
      <span class="label">{s.label}</span>
    </a>
  ))}
</div>

<style>
  .socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.5rem;
  }
  .socials a {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.9rem;
    border: 1px solid #222;
    border-radius: 6px;
    color: #888;
    text-decoration: none;
    font-size: 0.85rem;
    transition: border-color 0.2s, color 0.2s;
  }
  .socials a:hover { border-color: #555; color: #f0f0f0; }
  .icon { width: 16px; height: 16px; display: flex; }
  .icon svg { width: 100%; height: 100%; }
</style>
